APP_NAME=Lootora
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=lootora
DB_USERNAME=lootora
DB_PASSWORD=lootora_password
DB_ROOT_PASSWORD=root_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=public
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="hello@lootora.net"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Boot toggles for Docker entrypoint ----
AUTO_MIGRATE=true
AUTO_SEED=false

# ---- Docker Hub image (overridden in prod compose) ----
DOCKER_IMAGE=rinsella619/lootora:latest

# ---- Lootora reward defaults ----
LOOT_POINT_NAME="LOOT Points"
LOOT_POINT_SYMBOL="$LOOT"
LOOT_USD_TO_POINTS=1000
LOOT_DEFAULT_REVENUE_SHARE=70
LOOT_MIN_WITHDRAWAL_POINTS=5000
LOOT_REFERRAL_PERCENT=10
LOOT_DAILY_CHECKIN_POINTS=10
