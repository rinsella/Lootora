APP_NAME=Lootora
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://lootora.net

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lootora
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@lootora.net
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Google reCAPTCHA (anti-bot on register/login)
ENABLE_RECPTCHA=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Lootora reward engine
LOOT_POINT_NAME="LOOT Points"
LOOT_POINT_SYMBOL="$LOOT"
LOOT_USD_TO_POINTS=1000
LOOT_DEFAULT_REVENUE_SHARE=70
LOOT_MIN_WITHDRAWAL_POINTS=5000
LOOT_REFERRAL_PERCENT=10
LOOT_DAILY_CHECKIN_POINTS=10
LOOT_MAINTENANCE=false
